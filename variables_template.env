OPENCODE_CLI_PATH=opencode
OPENCODE_CLI_MODEL=gpt-5.5
OPENCODE_CLI_REASONING_EFFORT=xhigh
LOCAL_UPLOAD_DIR=local_storage/uploads
LOCAL_MEDIA_DIR=local_storage/media
LOCAL_SCREENSHOT_DIR=local_storage/screenshots
LOG_DIR=local_storage/logs
# Distributed queue root. Keep this separate from the project clone.
# Example on the Mini PC share host: D:\StudyReference\m2m_queue\_queue
M2M_QUEUE_ROOT=
# 可选，多个本地视频存档目录用英文分号分隔；URL 模式会尝试复用其中已下载的视频
LOCAL_VIDEO_ARCHIVE_DIRS=
# 如果 B站视频需要登录态，可导出浏览器 cookies.txt 后配置此文件路径
YTDLP_COOKIES_FILE=
ASR_PROVIDER=faster-whisper
ASR_LANGUAGE=auto
FASTER_WHISPER_MODEL=large-v3
FASTER_WHISPER_DEVICE=cuda
FASTER_WHISPER_COMPUTE_TYPE=float16
# 如果不需要密码访问，请留空或者删除此行
WEB_ACCESS_PASSWORD=
# 赛博洗稿文章提取的用户代理
# WASHING_USER_AGENT=
# 赛博洗稿文章提取超时（秒）
# WASHING_REQUEST_TIMEOUT=30
